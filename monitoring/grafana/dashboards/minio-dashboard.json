{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "MinIO Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 60 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "minio_node_process_uptime_seconds",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Storage Used",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "minio_cluster_usage_total_bytes",
          "legendFormat": "Used",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Objects",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "minio_cluster_usage_object_total",
          "legendFormat": "Objects",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Online Disks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "minio_cluster_disk_online_total",
          "legendFormat": "Online",
          "refId": "A"
        }
      ]
    },
    {
      "title": "S3 Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(minio_s3_requests_total[5m])) by (api)",
          "legendFormat": "{{api}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "S3 Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(minio_s3_requests_errors_total[5m])) by (api)",
          "legendFormat": "{{api}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "S3 Traffic - Received",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(minio_s3_traffic_received_bytes[5m]))",
          "legendFormat": "Received",
          "refId": "A"
        }
      ]
    },
    {
      "title": "S3 Traffic - Sent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(minio_s3_traffic_sent_bytes[5m]))",
          "legendFormat": "Sent",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Disk Used vs Free",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "minio_cluster_disk_total_used_bytes",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "minio_cluster_disk_total_free_bytes",
          "legendFormat": "Free",
          "refId": "B"
        }
      ]
    },
    {
      "title": "S3 Request Time to First Byte (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(minio_s3_requests_ttfb_seconds_distribution_bucket[5m])) by (le, api))",
          "legendFormat": "{{api}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["minio", "s3", "storage"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "MinIO",
  "uid": "minio-overview"
}